DATABASE_URL=postgresql+asyncpg://user:password@localhost/grove
GROQ_API_KEY=your_groq_api_key_here
JWT_SECRET=your_jwt_secret_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GEMINI_API_KEY=your_gemini_api_key_here
ADMIN_TOKEN=your_secure_admin_token_here

# App Environment (set "development" only for local testing, otherwise keep "production")
APP_ENV=production

# Comma-separated list of allowed CORS origins. Add production domains (e.g. Vercel) for deployment
# Format: http://localhost:3000,https://grove-xxx.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Order Status Timeouts (in seconds)
TIMEOUT_KONFIRMASI=86400
TIMEOUT_PENGAMBILAN=259200
TIMEOUT_AUTO_CONFIRM=172800
TIMEOUT_KOMPLAIN=86400
